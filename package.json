{
  "name": "country-data-finder",
  "version": "1.0.5",
  "description": "Get country name, flag URL, postal code format, and states/divisions by country code or country name",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "country",
    "country-info",
    "country-flag",
    "country-states",
    "country-code",
    "flag",
    "states",
    "divisions",
    "react-hook"
  ],
  "author": "MasudRana",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0"
  }
}
